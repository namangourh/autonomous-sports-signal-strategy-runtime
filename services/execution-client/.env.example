KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SOLANA_RPC_URL=https://api.devnet.solana.com
# Local dev: path to a keypair file.
SOLANA_WALLET_KEYPAIR_PATH=~/.config/solana/id.json
# Cloud deploy: JSON array of secret key bytes instead, e.g. `cat ~/.config/solana/id.json`.
# Takes precedence over SOLANA_WALLET_KEYPAIR_PATH if set. Never commit a real value.
SOLANA_WALLET_SECRET_KEY=
DRIFT_ENV=devnet
JUPITER_BASE_URL=https://lite-api.jup.ag
PAPER_TRADING=true
